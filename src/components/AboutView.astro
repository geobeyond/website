---
import InnerPage from "../layouts/InnerPage.astro";
import { pages } from "../i18n/pages";
import type { Locale } from "../i18n/home";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const c = pages[locale].about;
---

<InnerPage
  locale={locale}
  title={`${c.heading} — Geobeyond`}
  eyebrow={c.eyebrow}
  heading={c.heading}
  lead={c.lead}
>
  <div class="prose">
    {c.body.map((p) => <p>{p}</p>)}
  </div>
  <div class="stats">
    {
      c.stats.map((s) => (
        <div class="stat">
          <span class="stat-v">{s.value}</span>
          <span class="stat-l">{s.label}</span>
        </div>
      ))
    }
  </div>
</InnerPage>
